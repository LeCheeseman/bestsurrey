{
  "name": "bestsurrey",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env.local --import=tsx drizzle/seed/taxonomy.ts",
    "import:csv": "node --env-file=.env.local --import=tsx drizzle/import/run-import.ts --",
    "upload:image": "node --env-file=.env.local --import=tsx drizzle/import/upload-image.ts --"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "drizzle-orm": "^0.30.10",
    "next": "^14.2.0",
    "postgres": "^3.4.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.21.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
